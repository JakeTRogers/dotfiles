#compdef gcfuh

# Completion for the "gcfuh" (git commit fixup helper) command.
# Uses __git_fixup_commits_since_merge for commit hash completion.
function _gcfuh() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[Show help message]' \
    '1::commit:__git_fixup_commits_since_merge'
}

_gcfuh "$@"
