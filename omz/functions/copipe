#######################################
# copipe - pipe terminal input to GitHub Copilot
#######################################
if [[ $1 == "--help" || $1 == "-h" ]]; then
  fold -w "$(tput cols)" -s <<'EOF'
Usage: copipe [OPTIONS] [--preset PRESET] [--prompt TEXT]
Pipe terminal input to GitHub Copilot for analysis.

Reads from stdin by default, or from a file with -f/--file. Requires at least one of --prompt or --preset.

Options:
  -h, --help              Show this help
  -p, --prompt TEXT       Custom prompt text to include
  -f, --file FILE         Read input from FILE instead of stdin
  --preset PRESET         Use a built-in analysis preset
  --json                  Output in JSON format
  --model MODEL           Use a specific Copilot model
  --allow-tool TOOL       Allow a specific tool (repeatable)
  --show-prompt           Print the assembled prompt and exit

Presets:
  fix       Diagnose issues: likely cause, evidence, next steps
  diff      Review a diff: summary, risks, follow-ups
  explain   Explain input: what it is, key details, what to check

Examples:
  kubectl logs pod/foo | copipe --preset explain
  git diff HEAD~1 | copipe --preset diff --prompt "Focus on security"
  copipe -f error.log --preset fix --json
EOF
  return 0
fi

# Dependency check
if ! command -v copilot >/dev/null 2>&1; then
  pprint "🔴 copipe: 'copilot' command not found. Install GitHub Copilot CLI first." "$fgRed" >&2
  return 1
fi

# Local variables
local prompt_text=""
local preset=""
local file_path=""
local json_output=0
local model=""
local show_prompt=0
local -a allow_tools=()
local input=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      # Already handled above, but guard against mid-arg -h
      copipe --help
      return $?
      ;;
    -p|--prompt)
      if [[ -n "${2:-}" ]]; then
        prompt_text="$2"
        shift 2
      else
        pprint "🔴 copipe: --prompt requires a value" "$fgRed" >&2
        return 1
      fi
      ;;
    --prompt=*)
      prompt_text="${1#--prompt=}"
      shift
      ;;
    -f|--file)
      if [[ -n "${2:-}" ]]; then
        file_path="$2"
        shift 2
      else
        pprint "🔴 copipe: --file requires a value" "$fgRed" >&2
        return 1
      fi
      ;;
    --file=*)
      file_path="${1#--file=}"
      shift
      ;;
    --preset)
      if [[ -n "${2:-}" ]]; then
        preset="$2"
        shift 2
      else
        pprint "🔴 copipe: --preset requires a value" "$fgRed" >&2
        return 1
      fi
      ;;
    --preset=*)
      preset="${1#--preset=}"
      shift
      ;;
    --json)
      json_output=1
      shift
      ;;
    --model)
      if [[ -n "${2:-}" ]]; then
        model="$2"
        shift 2
      else
        pprint "🔴 copipe: --model requires a value" "$fgRed" >&2
        return 1
      fi
      ;;
    --model=*)
      model="${1#--model=}"
      shift
      ;;
    --allow-tool)
      if [[ -n "${2:-}" ]]; then
        allow_tools+=("$2")
        shift 2
      else
        pprint "🔴 copipe: --allow-tool requires a value" "$fgRed" >&2
        return 1
      fi
      ;;
    --allow-tool=*)
      allow_tools+=("${1#--allow-tool=}")
      shift
      ;;
    --show-prompt)
      show_prompt=1
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      pprint "🔴 copipe: unknown option: $1" "$fgRed" >&2
      return 1
      ;;
    *)
      pprint "🔴 copipe: unexpected argument: $1" "$fgRed" >&2
      return 1
      ;;
  esac
done

# Validate preset name
if [[ -n "$preset" ]] && [[ "$preset" != "fix" && "$preset" != "diff" && "$preset" != "explain" ]]; then
  pprint "🔴 copipe: unknown preset: $preset (choose from: fix, diff, explain)" "$fgRed" >&2
  return 1
fi

# Require at least one of --prompt or --preset
if [[ -z "$prompt_text" && -z "$preset" ]]; then
  pprint "🔴 copipe: at least one of --prompt or --preset is required" "$fgRed" >&2
  return 1
fi

# Read input: file takes precedence over stdin
if [[ -n "$file_path" ]]; then
  if [[ ! -r "$file_path" ]]; then
    pprint "🔴 copipe: cannot read file: $file_path" "$fgRed" >&2
    return 1
  fi
  input=$(<"$file_path")
else
  input=$(cat)
fi

# Validate input is not empty/whitespace-only
if [[ ! "$input" =~ [^[:space:]] ]]; then
  pprint "🔴 copipe: input is empty" "$fgRed" >&2
  return 1
fi

# Assemble prompt
local assembled=""

# Base instruction
assembled="You are analyzing terminal input provided via stdin.
Be concise, practical, and accurate. Do not invent facts not supported by the input."

# Preset section
case "$preset" in
  fix)
    assembled+="

Identify the likely issue from the input.
Cite the most relevant evidence from the input.
Suggest concrete next steps — prefer actionable commands when appropriate.
Structure your response as: Likely issue, Evidence, Next steps."
    ;;
  diff)
    assembled+="

Summarize the change shown in this diff.
Identify bugs, risky changes, missing tests, edge cases, security concerns, compatibility concerns, and operational risk when relevant.
If no clear issues are visible, say so.
Structure your response as: Summary, Risks / concerns, Suggested follow-ups."
    ;;
  explain)
    assembled+="

Explain what this input most likely represents.
Highlight the most important details or anomalies.
Identify what the user should pay attention to next.
Structure your response as: What this is, Key details, What to check next."
    ;;
esac

# User request section
if [[ -n "$prompt_text" ]]; then
  assembled+="

--- User request ---
$prompt_text"
fi

# Input block (always last)
assembled+="

--- Terminal input ---
<<<COPIPE_STDIN
$input
COPIPE_STDIN>>>"

# Show prompt mode
if [[ $show_prompt -eq 1 ]]; then
  echo "$assembled"
  return 0
fi

# Build copilot command arguments
local -a cmd_args=(copilot -p "$assembled" -s --no-ask-user)

if [[ $json_output -eq 1 ]]; then
  cmd_args+=(--output-format=json)
fi

if [[ -n "$model" ]]; then
  cmd_args+=(--model "$model")
fi

for tool in "${allow_tools[@]}"; do
  cmd_args+=(--allow-tool="$tool")
done

# Invoke copilot
"${cmd_args[@]}"
