#######################################
# gcfuh - git commit fixup helper
#######################################
if [[ $1 == "--help" || $1 == "-h" ]]; then
  fold -w "$(tput cols)" -s <<'EOF'
Usage: gcfuh [FILE...]
Interactive git commit --fixup helper using fzf.

Modes:
  No arguments    Select a target commit first, then pick files to include.
  With files      For each file, select which on-branch commit to fixup.
                  Files sharing the same target are grouped into one fixup.

This function helps you organize uncommitted changes into fixup commits for previous commits on your current branch.

Without arguments it provides a two-stage interactive selection:
  1. Select a target commit to fixup (from commits after the most recent merge)
  2. Select files to include in the fixup (grouped by their last commit)

With file arguments it provides per-file commit selection:
  - Each file is matched to the on-branch commits that touched it
  - If only one commit touched the file, it is auto-selected
  - Files with no on-branch history can be assigned to any on-branch commit
  - Files are grouped by selected target and one fixup commit is created per target

The function automatically unstages all files at start to prevent accidental inclusion. In no-args mode, it loops back if there are remaining changes.

Keybindings in fzf:
  No-args mode, file selection:
    TAB       Toggle selection
    CTRL-A    Select all
    CTRL-D    Deselect all
  Both modes:
    CTRL-/    Toggle preview
    ESC       Cancel and exit

Examples:
  gcfuh                     Interactive commit-first mode
  gcfuh path/to/file.sh     Per-file mode (auto-selects if one commit)
  gcfuh a.txt b.txt         Per-file mode (grouped fixup if same target)
EOF
  return 0
fi

# Use clean zsh emulation and disable debug output
setopt TYPESET_SILENT 2>/dev/null

# Ensure we're in a git repository
_fzf_git_check || return 1

# Separator for section headers (using box-drawing characters)
local SEP='─────────'
local DIM=$'\033[2m'
local ITALIC=$'\033[3m'
local RESET=$'\033[0m'
local YELLOW=$'\033[33m'
local GREEN=$'\033[32m'
local BLUE=$'\033[34m'

# Unstage all files to start fresh
git restore --staged . 2>/dev/null

# Find where current branch diverged from main branch
local merge_boundary
merge_boundary=$(git_find_branch_base)

# Build list of ALL on-branch commits (not just those with current changes)
# Exclude fixup commits (no fixup of fixup)
local -a unique_commits=()
local all_commits commit_line
all_commits=$(git log --format='%h %s' "${merge_boundary}..HEAD" 2>/dev/null)

while IFS= read -r commit_line; do
  [[ -z "$commit_line" ]] && continue
  # Skip fixup commits (subject starts with "fixup!")
  if [[ "$commit_line" =~ ^[a-f0-9]+\ fixup! ]]; then
    continue
  fi
  unique_commits+=("$commit_line")
done <<< "$all_commits"

# If no on-branch commits to fixup, inform user
if [[ ${#unique_commits[@]} -eq 0 ]]; then
  pprint "No on-branch commits found to fixup." "$fgYellow"
  return 0
fi

# ─── Files-passed mode ──────────────────────────────────────────────
if [[ $# -gt 0 ]]; then
  local -a passed_files=("$@")

  # Validate passed files: must have uncommitted changes according to git status
  local -a valid_files=()
  local status_output
  status_output=$(git status -s 2>/dev/null)
  for file in "${passed_files[@]}"; do
    if git status -s -- "$file" | grep -q .; then
      valid_files+=("$file")
    else
      pprint "Skipping unknown file: $file" "$fgYellow"
    fi
  done

  if [[ ${#valid_files[@]} -eq 0 ]]; then
    pprint "No valid files to process." "$fgYellow"
    return 0
  fi

  # Per-file commit selection
  local -A fixup_file_map=()    # target_hash -> newline-separated file list
  local -A fixup_subject_map=() # target_hash -> subject
  local -a fixup_order=()       # ordered unique target hashes

  for file in "${valid_files[@]}"; do
    # Find on-branch commits that touched this file (excluding fixup commits)
    local -a file_candidates=()
    local file_commits_output candidate_line
    file_commits_output=$(git log --format='%h %s' "${merge_boundary}..HEAD" -- "$file" 2>/dev/null)

    while IFS= read -r candidate_line; do
      [[ -z "$candidate_line" ]] && continue
      if [[ "$candidate_line" =~ ^[a-f0-9]+\ fixup! ]]; then
        continue
      fi
      file_candidates+=("$candidate_line")
    done <<< "$file_commits_output"

    # Fallback: if no on-branch commits touched this file, offer all on-branch commits
    if [[ ${#file_candidates[@]} -eq 0 ]]; then
      file_candidates=("${unique_commits[@]}")
    fi

    local target_hash target_subject

    if [[ ${#file_candidates[@]} -eq 1 ]]; then
      # Auto-select the single candidate
      target_hash="${file_candidates[1]%% *}"
      target_subject="${file_candidates[1]#* }"
      pprint "Auto-selected ${target_hash}: ${target_subject} for ${file}" "$fgGreen"
    else
      # Prompt user to select a commit for this file
      local escaped_file
      escaped_file=$(printf '%q' "$file")
      local selected
      selected=$(
        for candidate in "${file_candidates[@]}"; do
          echo "$candidate"
        done | _fzf_git_fzf --no-multi --ansi \
          --border-label "🔧 Select Fixup Target for ${file}" \
          --header $'Select which commit to fixup for this file\nCTRL-/ (toggle preview)\n' \
          --preview "hash=\$(echo {} | cut -d' ' -f1); git show --color=always \$hash -- ${escaped_file} 2>/dev/null | head -120"
      )

      if [[ -z "$selected" ]]; then
        pprint "Selection cancelled. No fixup commits were created." "$fgYellow"
        return 0
      fi

      target_hash="${selected%% *}"
      target_subject="${selected#* }"
    fi

    # Accumulate into grouped map
    if [[ -n "${fixup_file_map[$target_hash]}" ]]; then
      fixup_file_map[$target_hash]+=$'\n'"$file"
    else
      fixup_file_map[$target_hash]="$file"
      fixup_subject_map[$target_hash]="$target_subject"
      fixup_order+=("$target_hash")
    fi
  done

  # Confirmation prompt
  echo
  pprint "Fixup summary" "$fgCyan" "$txBold"
  echo
  for target_hash in "${fixup_order[@]}"; do
    local subject="${fixup_subject_map[$target_hash]}"
    pprint "  ${target_hash}: ${subject}" "$fgGreen"
    while IFS= read -r file; do
      echo "    $file"
    done <<< "${fixup_file_map[$target_hash]}"
  done
  echo

  local response
  printf '%b' "${fgYellow}Proceed? [y/N]:${txReset} "
  read -r response

  if [[ "$response" =~ ^[Yy]$ ]]; then
    for target_hash in "${fixup_order[@]}"; do
      local -a group_files=()
      while IFS= read -r file; do
        group_files+=("$file")
      done <<< "${fixup_file_map[$target_hash]}"

      git add "${group_files[@]}"
      if git commit --fixup "$target_hash"; then
        echo
        pprint "✓ Fixup commit created for ${target_hash}" "$fgGreen"
      else
        echo
        pprint "✗ Fixup commit failed for ${target_hash}" "$fgRed"
        return 1
      fi
    done
  else
    pprint "Aborted." "$fgYellow"
  fi

  return 0
fi

# ─── Commit-first mode (no arguments) ──────────────────────────────
# Main loop - continue while there are unstaged changes
while true; do
  # Check if there are any changes to work with
  local changes
  changes=$(git status -s 2>/dev/null)
  if [[ -z "$changes" ]]; then
    pprint "No uncommitted changes found." "$fgYellow"
    return 0
  fi

  # Build arrays for file categorization
  local -a on_branch_files=()
  local -a pre_merge_files=()
  local -a new_files=()
  local -A file_commits=()  # file -> "hash subject"

  # Process each changed file
  local file file_last_commit commit_info short_hash
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    file="${line:3}"

    # Handle renamed files (show destination)
    if [[ "$file" == *" -> "* ]]; then
      file="${file##* -> }"
    fi

    # Get the last commit for this file
    file_last_commit=$(git log -1 --format='%H' -- "$file" 2>/dev/null)

    if [[ -z "$file_last_commit" ]]; then
      # New file - no commit history
      new_files+=("$file")
    elif [[ -n "$merge_boundary" ]] && git merge-base --is-ancestor "$merge_boundary" "$file_last_commit" 2>/dev/null; then
      # File's last commit is after the merge boundary - on current branch
      commit_info=$(git log -1 --format='%h %s' -- "$file" 2>/dev/null)
      short_hash="${commit_info%% *}"
      file_commits[$file]="$commit_info"
      on_branch_files+=("$file")
    else
      # File's last commit is before/at the merge boundary
      pre_merge_files+=("$file")
    fi
  done <<< "$changes"

  # Stage 1: Select fixup target commit
  local target_commit target_hash target_subject

  target_commit=$(
    for commit in "${unique_commits[@]}"; do
      echo "$commit"
    done | _fzf_git_fzf --no-multi --ansi \
      --border-label '🔧 Select Fixup Target' \
      --header $'Select a commit to fixup\nCTRL-/ (toggle preview)\n' \
      --preview 'hash=$(echo {} | cut -d" " -f1); git show --color=always --stat $hash | head -50'
  )

  # Exit silently if user cancelled
  [[ -z "$target_commit" ]] && return 0

  target_hash="${target_commit%% *}"
  target_subject="${target_commit#* }"

  # Stage 2: Build file list with section headers
  local file_list=""

  # On-branch files (grouped by commit)
  if [[ ${#on_branch_files[@]} -gt 0 ]]; then
    # Group files by their commit hash, tracking encounter order
    local -A commit_files=()  # hash -> newline-separated list of files
    local -A commit_subjects=()  # hash -> subject
    local -a commit_order=()  # ordered list of unique commit hashes
    for file in "${on_branch_files[@]}"; do
      commit_info="${file_commits[$file]}"
      short_hash="${commit_info%% *}"
      subject="${commit_info#* }"
      commit_subjects[$short_hash]="$subject"
      if [[ -n "${commit_files[$short_hash]}" ]]; then
        commit_files[$short_hash]+=$'\n'"$file"
      else
        commit_files[$short_hash]="$file"
        commit_order+=("$short_hash")  # track first encounter
      fi
    done

    # Output files grouped under their commit headers (in encounter order)
    for short_hash in "${commit_order[@]}"; do
      subject="${commit_subjects[$short_hash]}"
      # Truncate subject to ~40 chars
      if [[ ${#subject} -gt 40 ]]; then
        subject="${subject:0:37}..."
      fi
      file_list+="${DIM}${ITALIC}${SEP} ${GREEN}${short_hash}${RESET}${DIM}${ITALIC}: ${subject} ${SEP}${RESET}"$'\n'
      while IFS= read -r file; do
        file_list+="  $file"$'\n'
      done <<< "${commit_files[$short_hash]}"
    done
  fi

  # Pre-merge files
  if [[ ${#pre_merge_files[@]} -gt 0 ]]; then
    file_list+="${DIM}${ITALIC}${SEP} ${BLUE}Pre-merge${RESET}${DIM}${ITALIC} (not on current branch) ${SEP}${RESET}"$'\n'
    for file in "${pre_merge_files[@]}"; do
      file_list+="  $file"$'\n'
    done
  fi

  # New files
  if [[ ${#new_files[@]} -gt 0 ]]; then
    file_list+="${DIM}${ITALIC}${SEP} ${YELLOW}New Files${RESET}${DIM}${ITALIC} (untracked) ${SEP}${RESET}"$'\n'
    for file in "${new_files[@]}"; do
      file_list+="  $file"$'\n'
    done
  fi

  # Stage 2: Select files
  local selected_files
  selected_files=$(
    echo -n "$file_list" | _fzf_git_fzf --multi --ansi \
      --border-label "📁 Select Files for ${target_hash} ${target_subject}" \
      --header $'Select files to include in fixup\nTAB (toggle) ╱ CTRL-A (all) ╱ CTRL-D (none)\n' \
      --bind 'ctrl-a:select-all,ctrl-d:deselect-all' \
      --preview "f=\$(echo {} | sed 's/^  //'); [[ -f \"\$f\" ]] && git diff --no-ext-diff --color=always -- \"\$f\" 2>/dev/null | head -100 || echo 'Section header'"
  )

  # Exit silently if user cancelled
  [[ -z "$selected_files" ]] && return 0

  # Filter out section headers and clean up file paths
  local -a files_to_add=()
  while IFS= read -r line; do
    # Skip separator lines
    [[ "$line" == *"$SEP"* ]] && continue
    # Remove leading spaces
    line="${line#  }"
    [[ -n "$line" ]] && files_to_add+=("$line")
  done <<< "$selected_files"

  # Check if any files were actually selected
  if [[ ${#files_to_add[@]} -eq 0 ]]; then
    pprint "No files selected." "$fgYellow"
    continue
  fi

  # Confirmation prompt
  local file_count=${#files_to_add[@]}
  local confirm_msg
  confirm_msg="Fixup ${file_count} file"
  [[ $file_count -gt 1 ]] && confirm_msg+="s"
  confirm_msg+=" into ${target_hash}: ${target_subject}"

  echo
  pprint "$confirm_msg" "$fgCyan" "$txBold"
  echo
  for f in "${files_to_add[@]}"; do
    echo "  $f"
  done
  echo

  local response
  printf '%b' "${fgYellow}Proceed? [y/N]:${txReset} "
  read -r response

  if [[ "$response" =~ ^[Yy]$ ]]; then
    # Execute the fixup
    git add "${files_to_add[@]}"
    if git commit --fixup "$target_hash"; then
      echo
      pprint "✓ Fixup commit created" "$fgGreen"
    else
      echo
      pprint "✗ Fixup commit failed" "$fgRed"
      return 1
    fi
  else
    pprint "Aborted." "$fgYellow"
  fi

  echo
done
