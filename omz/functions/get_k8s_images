#######################################
# get_k8s_images
#######################################
if [[ $1 == "--help" || $1 == "-h" ]]; then
  fold -w "$(tput cols)" -s <<'EOF'
Usage: get_k8s_images [OPTIONS] [NAMESPACE|-] [CONTEXT]
Get container images used by pods in a Kubernetes cluster.

Options (must come before positional arguments):
  -r, --running               Only include pods in Running state.
  -k, --kind <init,app,eph>   Container kinds to include (comma-separated).

Arguments:
  NAMESPACE   Namespace to query. Omit or use "-" for all namespaces.
  CONTEXT     Kubernetes context (defaults to current-context).

Examples:
  Get all images in all namespaces for the current context
    get_k8s_images
  Get all images in the kube-system namespace for the current context
    get_k8s_images kube-system
  Get all running images in all namespaces for the sandbox context
    get_k8s_images -r - sandbox
  Get all app container images in the cert-manager namespace for the sandbox context
    get_k8s_images --kind app cert-manager sandbox
EOF
  return 0
fi

# Dependency Checks
local tools=("kubectl")
for tool in "${tools[@]}"; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    pprint "$tool is required, but not found." "$fgRed"
    return 1
  fi
done

# Get the context of the cluster
cluster=${2:-$(kubectl config current-context)}

# if namespace is not provided, default to --all-namespaces
if [ -z "$1" ]; then
  kubectl --context "${cluster}" get pods --all-namespaces -o jsonpath="{.items[*].spec.containers[*].image}" | tr -s '[[:space:]]' '\n' | sort | uniq -c | column -t -s:
else
  kubectl --context "${cluster}" get pods -n "${1}" -o jsonpath="{.items[*].spec.containers[*].image}" | tr -s '[[:space:]]' '\n' | sort | uniq -c | column -t -s:
fi

return 0
